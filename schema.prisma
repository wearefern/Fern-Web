generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  hash               String               @id @unique
  createdAt          DateTime             @default(now()) @map(name: "created_at")
  ContentInteraction ContentInteraction[]

  @@map(name: "users")
}

model Content {
  slug               String               @id @unique
  createdAt          DateTime             @default(now()) @map(name: "created_at")
  ContentInteraction ContentInteraction[]

  @@map(name: "contents")
}

model ContentInteraction {
  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @updatedAt @map(name: "updated_at")
  seen      Boolean  @default(false)
  likes     Int      @default(0) @db.SmallInt()

  User     User   @relation(fields: [userHash], references: [hash])
  userHash String @map(name: "user_hash")

  Content     Content @relation(fields: [contentSlug], references: [slug])
  contentSlug String  @map(name: "content_slug")

  @@id(name: "interactionRelation", [userHash, contentSlug])
  @@map(name: "content_interactions")
}

model Product {
  id                 String      @id
  slug               String      @unique
  name               String
  category           String
  description        String
  longDescription    String
  priceLabel         String       @map(name: "price_label")
  priceCents         Int?         @map(name: "price_cents")
  isAvailable        Boolean      @default(true) @map(name: "is_available")
  format             String
  version            String
  fileSize           String       @map(name: "file_size")
  compatibility      String
  audioUrl           String       @map(name: "audio_url")
  macDownloadUrl     String       @map(name: "mac_download_url")
  windowsDownloadUrl String       @map(name: "windows_download_url")
  createdAt          DateTime     @default(now()) @map(name: "created_at")
  updatedAt          DateTime     @updatedAt @map(name: "updated_at")
  orderItems         OrderItem[]
  licenses           License[]

  @@map(name: "products")
}

model UserAccount {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @updatedAt @map(name: "updated_at")
  orders    Order[]
  licenses  License[]

  @@map(name: "user_accounts")
}

model Order {
  id             String      @id @default(cuid())
  externalRef    String      @unique @map(name: "external_ref")
  status         String
  subtotalCents  Int         @map(name: "subtotal_cents")
  totalCents     Int         @map(name: "total_cents")
  currency       String      @default("USD")
  paymentProvider String?    @map(name: "payment_provider")
  paymentRef     String?     @map(name: "payment_ref")
  createdAt      DateTime    @default(now()) @map(name: "created_at")
  updatedAt      DateTime    @updatedAt @map(name: "updated_at")
  userId         String      @map(name: "user_id")
  user           UserAccount @relation(fields: [userId], references: [id])
  items          OrderItem[]

  @@map(name: "orders")
}

model OrderItem {
  id            String  @id @default(cuid())
  quantity      Int
  unitPriceCents Int    @map(name: "unit_price_cents")
  lineTotalCents Int    @map(name: "line_total_cents")
  orderId       String  @map(name: "order_id")
  order         Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId     String  @map(name: "product_id")
  product       Product @relation(fields: [productId], references: [id])
  license       License?

  @@map(name: "order_items")
}

model License {
  id            String      @id @default(cuid())
  createdAt     DateTime    @default(now()) @map(name: "created_at")
  userId        String      @map(name: "user_id")
  user          UserAccount @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId     String      @map(name: "product_id")
  product       Product     @relation(fields: [productId], references: [id])
  orderItemId   String      @unique @map(name: "order_item_id")
  orderItem     OrderItem   @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  downloadEvents DownloadEvent[]

  @@unique([userId, productId])
  @@map(name: "licenses")
}

model DownloadEvent {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now()) @map(name: "created_at")
  platform   String
  ipAddress  String?  @map(name: "ip_address")
  userAgent  String?  @map(name: "user_agent")
  licenseId  String   @map(name: "license_id")
  license    License  @relation(fields: [licenseId], references: [id], onDelete: Cascade)

  @@map(name: "download_events")
}
